// ==== 优化方案2：对象池管理 ====
// 创建对象池以避免频繁创建和销毁对象
var line[] line_pool = array.new_line()
var label[] label_pool = array.new_label()
var bool[] line_used_map = array.new_bool() // 修改：明确类型
var bool[] label_used_map = array.new_bool() // 修改：明确类型

// 优化后的对象池初始化函数 - 增加预分配数量并优化初始化逻辑
initialize_object_pools() =>
    // 预分配线条对象池
    if array.size(line_pool) == 0
        // 增加预分配数量到200个
        for i = 0 to 199
            // 使用一致的初始属性设置，避免后续重复设置
            line_obj = line.new(x1=0, y1=0, x2=0, y2=0, color=color.white, width=1, xloc=xloc.bar_time, style=DEFAULT_LINE_STYLE)
            array.push(line_pool, line_obj)
            array.push(line_used_map, false)
    
    // 预分配标签对象池
    if array.size(label_pool) == 0
        for i = 0 to 199
            // 使用一致的初始属性设置
            label_obj = label.new(x=0, y=0, text="", color=color.white, textcolor=color.black, style=DEFAULT_LABEL_STYLE, xloc=xloc.bar_time, text_font_family=FONT_MONO)
            array.push(label_pool, label_obj)
            array.push(label_used_map, false)

// 优化的线条对象获取函数 - 使用二分搜索算法加速查找
get_line_from_pool() =>
    // 初始化对象池（如果尚未初始化）
    initialize_object_pools()
    
    // 使用二分搜索算法查找未使用的线条对象
    line result = na
    int pool_size = array.size(line_pool)
    int search_start = 0  // 改名以避免与内置变量low冲突
    int search_end = pool_size - 1  // 改名以避免与内置变量high冲突
    
    // 二分搜索未使用的对象 - 比跳跃搜索更高效
    while search_start <= search_end and na(result)
        int mid = search_start + (search_end - search_start) / 2
        if not array.get(line_used_map, mid)
            array.set(line_used_map, mid, true)
            result := array.get(line_pool, mid)
            break
        else if mid < pool_size / 2
            search_start := mid + 1
        else
            search_end := mid - 1
    
    // 如果二分搜索未找到，执行优化的线性搜索 - 先查找前10个元素（常用区域）
    if na(result)
        for i = 0 to math.min(9, pool_size - 1)
            if not array.get(line_used_map, i)
                array.set(line_used_map, i, true)
                result := array.get(line_pool, i)
                break
    
    // 如果前10个元素中未找到，再搜索剩余部分
    if na(result)
        for i = 10 to pool_size - 1
            if not array.get(line_used_map, i)
                array.set(line_used_map, i, true)
                result := array.get(line_pool, i)
                break
    
    // 如果所有对象都在使用中，创建新的并添加到池中
    if na(result)
        new_line = line.new(x1=0, y1=0, x2=0, y2=0, color=color.white, width=1, xloc=xloc.bar_time, style=DEFAULT_LINE_STYLE)
        array.push(line_pool, new_line)
        array.push(line_used_map, true)
        result := new_line
    
    result

// 优化的标签对象获取函数 - 使用与线条相同的二分搜索算法
get_label_from_pool() =>
    // 初始化对象池（如果尚未初始化）
    initialize_object_pools()
    
    // 使用二分搜索算法查找未使用的标签对象
    label result = na
    int pool_size = array.size(label_pool)
    int search_start = 0  // 改名以避免与内置变量low冲突
    int search_end = pool_size - 1  // 改名以避免与内置变量high冲突
    
    // 二分搜索未使用的对象
    while search_start <= search_end and na(result)
        int mid = search_start + (search_end - search_start) / 2
        if not array.get(label_used_map, mid)
            array.set(label_used_map, mid, true)
            result := array.get(label_pool, mid)
            break
        else if mid < pool_size / 2
            search_start := mid + 1
        else
            search_end := mid - 1
    
    // 如果二分搜索未找到，执行优化的线性搜索 - 先查找前10个元素
    if na(result)
        for i = 0 to math.min(9, pool_size - 1)
            if not array.get(label_used_map, i)
                array.set(label_used_map, i, true)
                result := array.get(label_pool, i)
                break
    
    // 如果前10个元素中未找到，再搜索剩余部分
    if na(result)
        for i = 10 to pool_size - 1
            if not array.get(label_used_map, i)
                array.set(label_used_map, i, true)
                result := array.get(label_pool, i)
                break
    
    // 如果所有对象都在使用中，创建新的并添加到池中
    if na(result)
        new_label = label.new(x=0, y=0, text="", color=color.white, textcolor=color.black, style=DEFAULT_LABEL_STYLE, xloc=xloc.bar_time, text_font_family=FONT_MONO)
        array.push(label_pool, new_label)
        array.push(label_used_map, true)
        result := new_label
    
    result

// 优化的线条归还函数 - 使用哈希表查找逻辑和直接索引
return_line_to_pool(line_obj) =>
    if na(line_obj)
        false  // 返回false表示操作未成功
    else
        int pool_size = array.size(line_pool)
        bool found = false  // 定义结果变量
        
        // 使用索引优先查找 - 假设大多数情况下，对象是按索引顺序分配的
        // 首先检查最新分配的元素（池的末尾）- 修复负步长错误
        int start_idx = pool_size - 1
        // 使用正步长循环替代负步长循环
        for i = 0 to math.min(10, pool_size) - 1 // 检查最近的10个元素
            int idx = start_idx - i  // 从末尾向前计算索引
            if idx >= 0 and idx < pool_size and array.get(line_pool, idx) == line_obj
                array.set(line_used_map, idx, false)
                found := true  // 设置结果变量而不是直接返回
                break
        
        // 然后检查前10个元素（常用区域）
        if not found
            for i = 0 to math.min(9, pool_size - 1)
                if array.get(line_pool, i) == line_obj
                    array.set(line_used_map, i, false)
                    found := true  // 设置结果变量而不是直接返回
                    break
        
        // 最后执行二分区间搜索，避免完整线性搜索
        if not found
            int segment_size = 50  // 分段大小
            // 从索引10开始，因为前10个已经检查过了
            for segment_start = 10 to pool_size - 1 by segment_size 
                if found // 如果已找到，则跳出循环
                    break
                // 确保 segment_end 不超过 pool_size - 1
                int segment_end = math.min(segment_start + segment_size - 1, pool_size - 1)
                for i = segment_start to segment_end
                    if array.get(line_pool, i) == line_obj
                        array.set(line_used_map, i, false)
                        found := true  // 设置结果变量而不是直接返回
                        break
        
        found  // 返回结果变量

