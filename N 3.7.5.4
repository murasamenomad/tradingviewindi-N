// ---- Rolling VWAP Function ----
f_rolling_vwap(days) =>
    time_window = days * 24 * 60 * 60 * 1000
    sum_src_vol = pc.totalForTimeWhen(vwapSource * volume, time_window, true, 10)
    sum_vol = pc.totalForTimeWhen(volume, time_window, true, 10)
    sum_vol == 0 ? na : sum_src_vol / sum_vol

// ---- 修改后的Rolling VWAP函数，适用于低时间框架 ----
f_rolling_vwap_for_small_tf(days, ref_tf) =>
    // 使用高一级的时间框架计算VWAP并返回
    request.security(syminfo.tickerid, ref_tf, f_rolling_vwap(days))

// ---- Anchored VWAP Helper Functions ----
f_is_new_period(anchor) =>
    anchor_tf = switch anchor
        'Day'     => 'D'
        'Week'    => 'W'
        'Month'   => 'M'
        'Quarter' => '3M'
        'Year'    => '12M'
        => ''
    anchor_tf == '' ? false : timeframe.change(anchor_tf)

// 基础VWAP计算函数 - 确保与anchored VWAP使用相同的计算逻辑
calculate_basic_vwap(src, reset_condition) =>
    float vwapValue = na
    float upperBand = na
    float lowerBand = na
    [_vwap, _stdev_upper_band, _] = ta.vwap(src, reset_condition, 1)
    if not na(_vwap)
        vwapValue := _vwap
        if not na(_stdev_upper_band)
            stdev_abs = _stdev_upper_band - vwapValue
            upperBand := vwapValue + stdev_abs
            lowerBand := vwapValue - stdev_abs
        else
            upperBand := na
            lowerBand := na
    [vwapValue, upperBand, lowerBand]

// 基于当前时间框架计算VWAP
f_calculate_current_vwap_native(src, is_active, is_new_period) =>
    float vwapValue = na
    float upperBand = na
    float lowerBand = na
    if is_active and not timeframe.isdwm
        [_vwap, _stdev_upper_band, _] = ta.vwap(src, is_new_period, 1)
        if not na(_vwap)
            vwapValue := _vwap
            if not na(_stdev_upper_band)
                stdev_abs = _stdev_upper_band - vwapValue
                upperBand := vwapValue + stdev_abs
                lowerBand := vwapValue - stdev_abs
            else
                upperBand := na
                lowerBand := na
        else
            vwapValue := na
            upperBand := na
            lowerBand := na
    [vwapValue, upperBand, lowerBand]

// 基于自适应时间框架计算VWAP
f_calculate_current_vwap_adaptive(src, is_active, anchor_period) =>
    float vwapValue = na
    float upperBand = na
    float lowerBand = na
    
    if is_active
        // 根据锚定周期类型确定VWAP类型
        string vwap_type = 'default'
        if anchor_period == 'Year'
            vwap_type := 'yearly'
        else if anchor_period == 'Quarter'
            vwap_type := 'quarterly'
        else if anchor_period == 'Month'
            vwap_type := 'monthly'
        else if anchor_period == 'Week'
            vwap_type := 'weekly'
        else if anchor_period == 'Day'
            vwap_type := 'daily'
        
        ref_tf = get_adaptive_anchor_tf(vwap_type) // 使用VWAP类型对应的自适应时间框架
        
        // 周期起点检测
        isWeekStart = dayofweek(time) == dayofweek.monday and (dayofweek(time[1]) != dayofweek.monday)
        isMonthStart = month(time) != month(time[1])
        isQuarterStart = get_quarter(time) != get_quarter(time[1])
        isYearStart = year(time) != year(time[1])
        isDayStart = dayofmonth(time) != dayofmonth(time[1]) or month(time) != month(time[1])
        
        period_start_condition = anchor_period == 'Week' ? isWeekStart : 
                               anchor_period == 'Month' ? isMonthStart : 
                               anchor_period == 'Quarter' ? isQuarterStart : 
                               anchor_period == 'Year' ? isYearStart : 
                               anchor_period == 'Day' ? isDayStart :
                               true // 默认情况(兼容)
        
        reset_condition = request.security(syminfo.tickerid, ref_tf, period_start_condition, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
        
        // 在自适应时间框架上计算VWAP
        [vwap_value, upper_band, lower_band] = request.security(syminfo.tickerid, ref_tf, calculate_basic_vwap(src, reset_condition), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
        
        vwapValue := vwap_value
        upperBand := upper_band
        lowerBand := lower_band
    
    [vwapValue, upperBand, lowerBand]

// 统一的VWAP计算函数，根据周期类型选择合适的计算方法
f_calculate_current_vwap(src, is_active, is_new_period, anchor_type) =>
    // 对于Day周期，使用原生计算；其他周期使用自适应时间框架计算
    if anchor_type == 'Day' and not use_adaptive_tf
        f_calculate_current_vwap_native(src, is_active, is_new_period)
    else
        f_calculate_current_vwap_adaptive(src, is_active, anchor_type)

// 获取特定时间框架上的VWAP值 - 使用自适应时间框架
get_fixed_tf_vwap(src, period_type) =>
    // 映射周期类型到VWAP类型
    string vwap_type = 'default'
    if period_type == 'Y'
        vwap_type := 'pyvwap'
    else if period_type == 'Q'
        vwap_type := 'pqvwap'
    else if period_type == 'M'
        vwap_type := 'pmvwap'
    else if period_type == 'W'
        vwap_type := 'pwvwap'
    else if period_type == 'D'
        vwap_type := 'daily'
    
    // 使用自适应时间框架计算VWAP，确保跨时间框架一致性
    ref_tf = get_adaptive_anchor_tf(vwap_type)
    
    // 通过request.security获取自适应时间框架上的VWAP
    reset_condition = request.security(syminfo.tickerid, ref_tf, period_type == 'W' ? dayofweek(time) == dayofweek.monday and (dayofweek(time[1]) != dayofweek.monday) : period_type == 'M' ? month(time) != month(time[1]) : period_type == 'Q' ? get_quarter(time) != get_quarter(time[1]) : period_type == 'Y' ? year(time) != year(time[1]) : period_type == 'D' ? dayofmonth(time) != dayofmonth(time[1]) or month(time) != month(time[1]) : false, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
    
    [vwap_value, upper_band, lower_band] = request.security(syminfo.tickerid, ref_tf, calculate_basic_vwap(src, reset_condition), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
    
    [vwap_value, upper_band, lower_band]

// ---- Previous Period VWAP Functions ----
// 计算周期VWAP - 原始方法，在当前时间框架上计算
calculate_period_vwap(src, tf_string) =>
    isNewPeriod = timeframe.change(tf_string)
    [vwap, upper, lower] = calculate_basic_vwap(src, isNewPeriod)
    [vwap, upper, lower]

// 检测周期变化的函数
detect_period_change(period) =>
    switch period
        'W' => dayofweek(time) == dayofweek.monday and (dayofweek(time[1]) != dayofweek.monday)
        'M' => month(time) != month(time[1])
        'Q' => get_quarter(time) != get_quarter(time[1])
        'Y' => year(time) != year(time[1])
        => false

// 计算并存储上一周期的VWAP (适用于任何时间框架，确保一致性)
calculate_and_store_previous_vwap(period) =>
    is_tf_change = detect_period_change(period)
    float poc = na
    float upper = na
    float lower = na
    int start_index = na
    
    // 始终使用固定时间框架计算VWAP，确保一致性
    [cur_poc, cur_upper, cur_lower] = get_fixed_tf_vwap(vwapSource, period)
    
    // 如果检测到周期变化，存储上一周期的值
    if is_tf_change
        poc := cur_poc[1]
        upper := cur_upper[1]
        lower := cur_lower[1]
        start_index := bar_index
    
    [poc, upper, lower, start_index]

