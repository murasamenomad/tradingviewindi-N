// ---- Key Open Level Calculations ----
bool valid_yearOpen = not na(yearOpen_ref) and yearOpen_ref > 0
bool valid_monthOpen = not na(monthOpen_ref) and monthOpen_ref > 0
bool valid_weekOpen = not na(weekOpen_ref) and weekOpen_ref > 0
bool valid_quarterOpen = not na(quarterOpen_ref) and quarterOpen_ref > 0
bool valid_dailyOpen = not na(dailyOpen_ref) and dailyOpen_ref > 0

if isNewMonth or na(monthlyOpen[1])
    monthlyOpen := valid_monthOpen and use_ref_tf_for_opens ? monthOpen_ref : open
if isNewYear or na(yearlyOpen[1])
    yearlyOpen := valid_yearOpen and use_ref_tf_for_opens ? yearOpen_ref : open
if isNewWeek or na(weeklyOpen[1])
    weeklyOpen := valid_weekOpen and use_ref_tf_for_opens ? weekOpen_ref : open
if isNewQuarter or na(quarterlyOpen[1])
    quarterlyOpen := valid_quarterOpen and use_ref_tf_for_opens ? quarterOpen_ref : open
