                if not na(temp_vpoc)
                    temp_vpoc.delete()
                if not na(temp_line)
                    temp_line.delete()
                if not na(temp_label)
                    temp_label.delete()
                    
                if show_vpoc and not na(max_y)
                    line vpoc_line = line.new(lb_time, max_y, time, max_y, 
                                             xloc = xloc.bar_time, color = vpoc_color, width = 1)
                    array.unshift(vpoc, vpoc_line)
                    if array.size(vpoc) > 10 
                        line old_line = array.pop(vpoc)
                        old_line.delete()
            else
                if show_vp and array.size(points_array) > 2
                    PL := polyline.new(points_array, curved = false, closed = true, 
                                      line_color = vp_color, fill_color = vp_color, xloc = xloc.bar_time)
                
                if show_vpoc and not na(max_y)
                    if na(temp_vpoc)
                        temp_vpoc := line.new(lb_time, max_y, time, max_y, 
                                             xloc = xloc.bar_time, color = vpoc_color, width = 1)
                        temp_line := line.new(time, max_y, time + (pvwap_offset * timeframe.in_seconds() * 1000), max_y, 
                                             xloc = xloc.bar_time, color = vpoc_color, 
                                             width = 1, style=line.style_dotted)
                        temp_label := label.new(time + (pvwap_offset * timeframe.in_seconds() * 1000), max_y, text = "POC", 
                                               tooltip = str.tostring(max_y, pvwap_format_level), 
                                               color = color.new(color.black, 100), textcolor = vpoc_color, 
                                               style = label.style_label_left, xloc = xloc.bar_time, 
                                               text_font_family = FONT_MONO)
                        array.push(vpoc_labels, temp_label)
                    else
                        temp_vpoc.set_y1(max_y)
                        temp_vpoc.set_xy2(time, max_y)
                        temp_line.set_xy1(bar_index, max_y) // bar_index might be an issue here, consider time
                        temp_line.set_xy2(bar_index + pvwap_offset, max_y)
                        temp_label.set_xy(bar_index + pvwap_offset, max_y)
                        temp_label.set_tooltip(str.tostring(max_y, pvwap_format_level))
                else if not na(temp_vpoc)
                    temp_vpoc.delete()
                    temp_line.delete()
                    temp_label.delete()
                    temp_vpoc := na
                    temp_line := na
                    temp_label := na

if enable_vp and timeframe.change(tf)
