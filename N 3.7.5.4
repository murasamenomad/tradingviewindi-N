    dailyOpen := valid_dailyOpen and use_ref_tf_for_opens ? dailyOpen_ref : open

// ---- Monday Range Calculation ----
bool isMondayNow = dayofweek(time) == dayofweek.monday
if isNewWeek
    prevMondayHigh := mondayHigh
    prevMondayLow := mondayLow
    prevMondayStartBar := mondayStartBar
    prevWeekEndBar := bar_index[1]
    mondayHigh := na
    mondayLow := na
    mondayStartBar := na
    mondayEndBar := na
if isMondayNow
    if na(mondayStartBar)
        mondayStartBar := bar_index
        mondayHigh := high
        mondayLow := low
    else
        mondayHigh := math.max(na(mondayHigh) ? high : mondayHigh, high)
        mondayLow := math.min(na(mondayLow) ? low : mondayLow, low)
    mondayEndBar := bar_index

// ---- Volume Profile Calculations ====
ltf := timeframe.in_seconds(ltf) <= timeframe.in_seconds() ? ltf : ''

if enable_vp
    if na(vpoc) or na(values) or na(x_vol) or na(y_vol)
        vpoc := array.new_line()
        values := array.new_float()
        x_vol := array.new_int()
        y_vol := array.new_float()
        
    [ltf_H, ltf_L, ltf_V] = request.security_lower_tf(syminfo.tickerid, ltf, [high, low, volume])

    if not na(lb_idx)
        lb = bar_index - lb_idx > 0 ? bar_index - lb_idx : 1
        y_max = ta.highest(high[1], lb)
        y_min = ta.lowest(low[1], lb)

        if timeframe.change(tf) or barstate.islast
            array.clear(x_vol)
            array.clear(y_vol)
            array.clear(values)

            for i = 0 to rows - 1
                y = y_min + i * (y_max - y_min) / rows
                array.push(x_vol, lb_time)
                array.push(y_vol, y)
                array.push(values, 0)

            float total_vol = 0
            
            for i = 0 to lb - 1
                if i < bar_index
                    float h = high[i]
                    float l = low[i]
                    float v = volume[i]
                    
                    if not na(h) and not na(l) and not na(v) and v > 0
                        total_vol += v
                        for j = 0 to rows - 1
                            price_level = y_vol.get(j)
                            if price_level >= l and price_level <= h
                                vol_contribution = v / ((h - l) / (y_max - y_min) * rows)
                                values.set(j, values.get(j) + vol_contribution)

            int max_index = 0
            float max_value = 0
            
            for i = 0 to array.size(values) - 1
                if values.get(i) > max_value
                    max_value := values.get(i)
                    max_index := i
            
            float max_y = max_index < array.size(y_vol) ? y_vol.get(max_index) : na
            float scale_factor = max_value > 0 ? max_value / (time - lb_time) / (extend / 100) : 1

            for j = 0 to array.size(values) - 1
                x_value = lb_time + math.floor(values.get(j) / scale_factor)
                x_vol.set(j, x_value)

            var chart.point[] points_array = na
            if na(points_array)
                points_array := array.new<chart.point>()
            else
                array.clear(points_array)
            
            array.push(points_array, chart.point.from_time(lb_time, y_min))
            for i = 0 to array.size(x_vol) - 1
                if i < array.size(y_vol)
                    array.push(points_array, chart.point.from_time(x_vol.get(i), y_vol.get(i)))
            array.push(points_array, chart.point.from_time(lb_time, y_max))

            if not na(PL)
                PL.delete()
                
            if timeframe.change(tf)
                if show_vp and array.size(points_array) > 2
                    polyline.new(points_array, curved = false, closed = true, 
